{% extends 'landing/layout/page.html.twig' %}


{% block body %}
	<section class="py-5 my-4 position-relative">
		<div class="container">
			<h1 class="display-6 fw-bold text-white mb-4">
				Câu Hỏi Thường Gặp (FAQ)
			</h1>
			<div class="accordion" id="faqAccordion">
				<div class="accordion-item mb-2">
					<h2 class="accordion-header" id="faq1">
						<button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse1" aria-expanded="false" aria-controls="collapse1">
							Không thấy server game mình cần, phải làm sao?
						</button>
					</h2>
					<div id="collapse1" class="accordion-collapse collapse" aria-labelledby="faq1" data-bs-parent="#faqAccordion">
						<div class="accordion-body">
							Nếu không thấy server game được hỗ trợ sẵn, bạn có thể liên hệ với chúng tôi để được hỗ trợ thêm server hoàn toàn miễn phí.
						</div>
					</div>
				</div>
				<div class="accordion-item mb-2">
					<h2 class="accordion-header" id="faq2">
						<button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse2" aria-expanded="false" aria-controls="collapse2">
							Nạp tiền có hoàn lại không?
						</button>
					</h2>
					<div id="collapse2" class="accordion-collapse collapse" aria-labelledby="faq2" data-bs-parent="#faqAccordion">
						<div class="accordion-body">
							Số tiền đã nạp sẽ không được hoàn lại. Tuy nhiên, trong một số trường hợp đặc biệt, bạn có thể liên hệ để được xem xét hỗ trợ.
						</div>
					</div>
				</div>
				<div class="accordion-item mb-2">
					<h2 class="accordion-header" id="faq3">
						<button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse3" aria-expanded="false" aria-controls="collapse3">
							Server đã khởi tạo có thể hoàn lại không?
						</button>
					</h2>
					<div id="collapse3" class="accordion-collapse collapse" aria-labelledby="faq3" data-bs-parent="#faqAccordion">
						<div class="accordion-body">
							Sau khi server đã được khởi tạo, chúng tôi không hỗ trợ hoàn lại tiền cho dịch vụ này.
						</div>
					</div>
				</div>
				<div class="accordion-item mb-2">
					<h2 class="accordion-header" id="faq4">
						<button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse4" aria-expanded="false" aria-controls="collapse4">
							Khi server hết ổ cứng hoặc RAM có thể nâng cấp không?
						</button>
					</h2>
					<div id="collapse4" class="accordion-collapse collapse" aria-labelledby="faq4" data-bs-parent="#faqAccordion">
						<div class="accordion-body">
							Có, bạn hoàn toàn có thể nâng cấp thêm ổ cứng hoặc RAM cho server. Hãy liên hệ với chúng tôi để được hỗ trợ nhanh nhất.
						</div>
					</div>
				</div>
				<div class="accordion-item mb-2">
					<h2 class="accordion-header" id="faq6">
						<button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse6" aria-expanded="false" aria-controls="collapse6">
							Bao lâu thì dữ liệu sẽ bị xoá khi server hết hạn?
						</button>
					</h2>
					<div id="collapse6" class="accordion-collapse collapse" aria-labelledby="faq6" data-bs-parent="#faqAccordion">
						<div class="accordion-body">
							Server sẽ bị xoá sau 30 ngày kể từ khi hết hạn. Để tránh mất dữ liệu, bạn nên gia hạn dịch vụ hoặc tạo một bản backup và tải xuống máy tính cá nhân để lưu trữ an toàn.
						</div>
					</div>
				</div>
				<div class="accordion-item mb-2">
					<h2 class="accordion-header" id="faq5">
						<button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse5" aria-expanded="false" aria-controls="collapse5">
							Server có thể chạy 24/7 không?
						</button>
					</h2>
					<div id="collapse5" class="accordion-collapse collapse" aria-labelledby="faq5" data-bs-parent="#faqAccordion">
						<div class="accordion-body">
							Có, tất cả các server đều được thiết kế để hoạt động liên tục 24/7, đảm bảo trải nghiệm không gián đoạn cho bạn.
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>
{% endblock %}
